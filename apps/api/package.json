{
  "name": "@hutanotrack/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:migrate": "ts-node -r tsconfig-paths/register src/database/migrations/run.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seeds/run.ts"
  },
  "dependencies": {
    "@hutanotrack/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/throttler": "^6.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^5.0.0",
    "typeorm": "^0.3.20",
    "pg": "^8.13.0",
    "sql.js": "^1.11.0",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "bcrypt": "^5.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "helmet": "^8.0.0",
    "compression": "^1.7.4",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/compression": "^1.7.5",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "ts-loader": "^9.5.1"
  }
}
