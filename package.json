{
  "name": "hutanotrack",
  "private": true,
  "version": "0.1.0",
  "description": "HutanoTrack - Keeping Communities Connected to Care",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:migrate": "turpo run db:migrate --filter=@hutanotrack/api",
    "db:seed": "turpo run db:seed --filter=@hutanotrack/api",
    "clean": "turpo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
